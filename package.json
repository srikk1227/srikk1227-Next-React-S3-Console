    "eslint-config-next": "15.4.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://next-react-s3-console.xyz"
